## ============================================================
##  Custom hit.vm — with keyword highlighting (titre + description)
## ============================================================

#set($docId = $doc.getFieldValue("id"))

## ---------- Highlighting ----------
#set($hl = $response.response.highlighting.get($docId))

#set($titleHL = "")
#if($hl && $hl.get("titre"))
  #set($titleHL = $hl.get("titre")[0])
#end

#set($descHL = "")
#if($hl && $hl.get("description"))
  #set($descHL = $hl.get("description")[0])
#end

## ---------- Raw fields ----------
#set($titre = $doc.getFieldValue("titre"))
#set($description = $doc.getFieldValue("description"))

#set($duree = $doc.getFieldValue("duree_min"))
#set($orgNom = $doc.getFieldValue("org_nom"))
#set($orgAdr = $doc.getFieldValue("org_adresse"))
#set($cp = $doc.getFieldValue("code_postal"))
#set($commune = $doc.getFieldValue("commune"))
#set($url = $doc.getFieldValue("url"))

<div class="result-document">

  <!-- ======================= TITRE ======================= -->
  <h2 class="result-title">
    #if($titleHL && $titleHL != "")
      $titleHL
    #else
      $!titre
    #end
  </h2>

  <!-- ======================= DUREE ======================= -->
  #if($duree)
    <div><b>Durée :</b> $duree h</div>
  #end

  <!-- ======================= LIEU ========================= -->
  <div class="result-location">
    <b>Lieu :</b>
    $!orgNom
    #if($orgAdr), $orgAdr#end
    #if($cp), $cp#end
    #if($commune), $commune#end
  </div>

  <!-- ======================= DESCRIPTION ================== -->
  #if($descHL && $descHL != "")
    <div class="result-description">
      <b>Description :</b> $descHL
      #if($url)
        <a href="$url" target="_blank">Lire la suite</a>
      #end
    </div>

  #elseif($description)
    ## 只取第一句
    #set($sentences = $description.split("\\."))
    #set($firstSentence = $sentences[0] + ".")
    <div class="result-description">
      <b>Description :</b> $firstSentence
      #if($url)
        <a href="$url" target="_blank">Lire la suite</a>
      #end
    </div>
  #end

</div>
